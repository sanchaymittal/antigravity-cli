{
  "name": "@sanchaymittal/antigravity-cli",
  "version": "0.1.0",
  "description": "CLI for Antigravity — chat with Claude, Gemini, and GPT-OSS via your Antigravity subscription",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ag": "src/cli.js"
  },
  "files": [
    "src/agent.js",
    "src/cli.js",
    "src/images.js",
    "src/model-enum.js",
    "src/models.js",
    "src/repl.js",
    "src/ui.js",
    "src/utils.js",
    "src/mcp/",
    "src/sidecar/",
    "src/tools/",
    "src/tui/",
    "src/tui/App.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test tests/**/*.test.js",
    "build": "esbuild src/tui/App.js --jsx=transform --platform=node --format=cjs --outfile=src/tui/App.cjs --loader:.js=jsx",
    "prepare": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "figlet": "^1.11.0",
    "ink": "^3.2.0",
    "ink-text-input": "^4.0.3",
    "marked": "^4.3.0",
    "marked-terminal": "^5.2.0",
    "ora": "^5.4.1",
    "react": "^17.0.2"
  },
  "keywords": [
    "antigravity",
    "ai",
    "cli",
    "claude",
    "gemini",
    "gpt",
    "llm"
  ],
  "license": "MIT",
  "author": "sanchaymittal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanchaymittal/antigravity-cli.git"
  },
  "bugs": {
    "url": "https://github.com/sanchaymittal/antigravity-cli/issues"
  },
  "homepage": "https://github.com/sanchaymittal/antigravity-cli#readme",
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
